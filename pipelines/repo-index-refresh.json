{
  "name": "repo-index-refresh",
  "schedule": "0 6 * * *",
  "project": "meta",
  "steps": [
    {
      "step": "summary-meta",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/meta/scripts --refresh --no-llm",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "summary-intel",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/intel/tools --refresh --no-llm --compact",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "summary-research-mcp",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/research-mcp/src --refresh --no-llm",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "summary-genomics",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/genomics --refresh --no-llm --compact",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "map-meta",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/meta --source-dirs scripts",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "map-intel",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/intel --source-dirs tools,analysis",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "map-research-mcp",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/research-mcp --source-dirs src",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "map-genomics",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/genomics --source-dirs scripts",
      "cwd": "~/Projects/meta"
    }
  ]
}
