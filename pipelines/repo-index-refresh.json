{
  "name": "repo-index-refresh",
  "schedule": "0 6 * * *",
  "project": "agent-infra",
  "steps": [
    {
      "step": "summary-agent-infra",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/agent-infra/scripts --refresh --no-llm",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "summary-intel",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/intel/tools --refresh --no-llm --compact",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "summary-research-mcp",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/research-mcp/src --refresh --no-llm",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "summary-genomics",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/genomics --refresh --no-llm --compact",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "summary-phenome",
      "type": "script",
      "command": "uv run python3 scripts/repo-summary.py ~/Projects/phenome/scripts --refresh --no-llm && uv run python3 scripts/repo-summary.py ~/Projects/phenome/src --refresh --no-llm",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "map-agent-infra",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/agent-infra --source-dirs scripts",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "map-intel",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/intel --source-dirs tools,analysis",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "map-research-mcp",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/research-mcp --source-dirs src",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "map-genomics",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/genomics --source-dirs scripts",
      "cwd": "~/Projects/agent-infra"
    },
    {
      "step": "map-phenome",
      "type": "script",
      "command": "uv run python3 scripts/codebase-map.py ~/Projects/phenome --source-dirs scripts,src",
      "cwd": "~/Projects/agent-infra"
    }
  ]
}
