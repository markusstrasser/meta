{
  "name": "substrate-sync",
  "description": "Daily ingest docs into knowledge substrate",
  "schedule": 6,
  "project": "meta",
  "steps": [
    {
      "step": "ingest-intel",
      "type": "script",
      "command": "uv run python3 substrate/ingest_intel.py",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "ingest-selve",
      "type": "script",
      "command": "uv run python3 substrate/ingest_selve.py",
      "cwd": "~/Projects/meta"
    },
    {
      "step": "balance-check",
      "type": "script",
      "command": "uv run python3 scripts/knowledge-balance-check.py",
      "cwd": "~/Projects/meta"
    }
  ]
}
